{
  "name": "vscode-s3",
  "displayName": "%displayName%",
  "description": "%description%",
  "icon": "logo.png",
  "version": "1.1.4",
  "publisher": "nntk",
  "engines": {
    "vscode": "^1.89.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:s3Explorer",
    "onCommand:s3.addConnection",
    "onCommand:s3.editConnection",
    "onCommand:s3.openSettings",
    "onCommand:s3.refresh",
    "onCommand:s3.goToPath",
    "onCommand:s3.bucketInfo",
    "onCommand:s3.openConnection"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "s3-browser",
          "title": "%viewContainerTitle%",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "s3-browser": [
        {
          "id": "s3Explorer",
          "name": "%viewName%"
        }
      ]
    },
    "commands": [
      {
        "command": "s3.openSettings",
        "title": "%cmd.openSettings%",
        "icon": "$(gear)"
      },
      {
        "command": "s3.addConnection",
        "title": "%cmd.addConnection%",
        "icon": "$(plus)"
      },
      {
        "command": "s3.refresh",
        "title": "%cmd.refresh%",
        "icon": "$(refresh)"
      },
      {
        "command": "s3.editConnection",
        "title": "%cmd.editConnection%",
        "icon": "$(edit)"
      },
      {
        "command": "s3.deleteConnection",
        "title": "%cmd.removeConnection%",
        "icon": "$(close)"
      },
      {
        "command": "s3.goToPath",
        "title": "%cmd.goToPath%",
        "icon": "$(arrow-right)"
      },
      {
        "command": "s3.openConnection",
        "title": "%cmd.openConnection%",
        "icon": "$(folder-opened)"
      },
      {
        "command": "s3.bucketInfo",
        "title": "%cmd.bucketInfo%",
        "icon": "$(info)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "s3.openSettings",
          "when": "view == s3Explorer",
          "group": "navigation"
        },
        {
          "command": "s3.addConnection",
          "when": "view == s3Explorer",
          "group": "navigation"
        },
        {
          "command": "s3.refresh",
          "when": "view == s3Explorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "s3.editConnection",
          "when": "view == s3Explorer && viewItem == s3Connection",
          "group": "inline"
        },
        {
          "command": "s3.bucketInfo",
          "when": "view == s3Explorer && viewItem == s3Connection",
          "group": "inline"
        },
        {
          "command": "s3.deleteConnection",
          "when": "view == s3Explorer && viewItem == s3Connection",
          "group": "1_modification"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "node scripts/build.js",
    "compile": "node scripts/build.js",
    "watch": "node scripts/build.js --watch",
    "lint": "echo 'no linter configured'"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.89.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
    "esdk-obs-nodejs": "^3.26.2",
    "http-proxy-agent": "^9.1.0",
    "https-proxy-agent": "^9.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://your-private-repo-url"
  }
}
