{
  "name": "vscode-s3",
  "displayName": "%displayName%",
  "description": "%description%",
  "icon": "logo.png",
  "version": "1.0.3",
  "publisher": "nntk",
  "engines": {
    "vscode": "^1.89.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:s3Explorer",
    "onCommand:s3.addConnection",
    "onCommand:s3.editConnection",
    "onCommand:s3.refresh",
    "onCommand:s3.uploadFile",
    "onCommand:s3.downloadFile",
    "onCommand:s3.deleteObject",
    "onCommand:s3.deleteConnection",
    "onCommand:s3.copyPath",
    "onCommand:s3.previewFile",
    "onCommand:s3.rename",
    "onCommand:s3.newFolder",
    "onCommand:s3.searchFiles",
    "onCommand:s3.goToPath",
    "onCommand:s3.getInfo",
    "onCommand:s3.jumpHistory"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "s3-browser",
          "title": "%viewContainerTitle%",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "s3-browser": [
        {
          "id": "s3Explorer",
          "name": "%viewName%"
        }
      ]
    },
    "commands": [
      {
        "command": "s3.addConnection",
        "title": "%cmd.addConnection%",
        "icon": "$(plus)"
      },
      {
        "command": "s3.refresh",
        "title": "%cmd.refresh%",
        "icon": "$(refresh)"
      },
      {
        "command": "s3.uploadFile",
        "title": "%cmd.uploadFile%",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "s3.downloadFile",
        "title": "%cmd.downloadFile%",
        "icon": "$(cloud-download)"
      },
      {
        "command": "s3.deleteObject",
        "title": "%cmd.delete%",
        "icon": "$(trash)"
      },
      {
        "command": "s3.editConnection",
        "title": "%cmd.editConnection%",
        "icon": "$(edit)"
      },
      {
        "command": "s3.deleteConnection",
        "title": "%cmd.removeConnection%",
        "icon": "$(close)"
      },
      {
        "command": "s3.copyPath",
        "title": "%cmd.copyPath%",
        "icon": "$(link)"
      },
      {
        "command": "s3.previewFile",
        "title": "%cmd.previewFile%",
        "icon": "$(eye)"
      },
      {
        "command": "s3.rename",
        "title": "%cmd.rename%",
        "icon": "$(symbol-misc)"
      },
      {
        "command": "s3.newFolder",
        "title": "%cmd.newFolder%",
        "icon": "$(new-folder)"
      },
      {
        "command": "s3.searchFiles",
        "title": "%cmd.searchFiles%",
        "icon": "$(search)"
      },
      {
        "command": "s3.goToPath",
        "title": "%cmd.goToPath%",
        "icon": "$(arrow-right)"
      },
      {
        "command": "s3.getInfo",
        "title": "%cmd.getInfo%",
        "icon": "$(info)"
      },
      {
        "command": "s3.jumpHistory",
        "title": "%cmd.jumpHistory%",
        "icon": "$(history)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "s3.addConnection",
          "when": "view == s3Explorer",
          "group": "navigation"
        },
        {
          "command": "s3.refresh",
          "when": "view == s3Explorer",
          "group": "navigation"
        },
        {
          "command": "s3.jumpHistory",
          "when": "view == s3Explorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "s3.searchFiles",
          "when": "view == s3Explorer && (viewItem == s3Connection || viewItem == s3Folder)",
          "group": "inline"
        },
        {
          "command": "s3.uploadFile",
          "when": "view == s3Explorer && viewItem == s3Connection",
          "group": "inline"
        },
        {
          "command": "s3.uploadFile",
          "when": "view == s3Explorer && viewItem == s3Folder",
          "group": "inline"
        },
        {
          "command": "s3.downloadFile",
          "when": "view == s3Explorer && viewItem == s3File",
          "group": "inline"
        },
        {
          "command": "s3.previewFile",
          "when": "view == s3Explorer && viewItem == s3File",
          "group": "inline"
        },
        {
          "command": "s3.getInfo",
          "when": "view == s3Explorer && viewItem == s3File",
          "group": "inline"
        },
        {
          "command": "s3.copyPath",
          "when": "view == s3Explorer && (viewItem == s3File || viewItem == s3Folder)",
          "group": "inline"
        },
        {
          "command": "s3.refresh",
          "when": "view == s3Explorer && (viewItem == s3Folder || viewItem == s3Connection)",
          "group": "inline"
        },
        {
          "command": "s3.editConnection",
          "when": "view == s3Explorer && viewItem == s3Connection",
          "group": "inline"
        },
        {
          "command": "s3.goToPath",
          "when": "view == s3Explorer && (viewItem == s3Connection || viewItem == s3Folder)",
          "group": "inline"
        },
        {
          "command": "s3.rename",
          "when": "view == s3Explorer && (viewItem == s3File || viewItem == s3Folder)",
          "group": "1_modification"
        },
        {
          "command": "s3.newFolder",
          "when": "view == s3Explorer && (viewItem == s3Connection || viewItem == s3Folder)",
          "group": "1_modification"
        },
        {
          "command": "s3.deleteObject",
          "when": "view == s3Explorer && (viewItem == s3File || viewItem == s3Folder)",
          "group": "2_delete"
        },
        {
          "command": "s3.deleteConnection",
          "when": "view == s3Explorer && viewItem == s3Connection",
          "group": "2_delete"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "node scripts/build.js",
    "compile": "node scripts/build.js",
    "watch": "node scripts/build.js --watch",
    "lint": "echo 'no linter configured'"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.89.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0"
  }
}
